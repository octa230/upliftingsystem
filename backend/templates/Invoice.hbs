<html>
  <head>
    <title>Tax Invoice — {{sale.InvoiceCode}}</title>
    <style>
      :root {
        --accent: #FFE066;
        --dark:   #1a1a1a;
        --mid:    #555555;
        --light:  #888888;
        --border: #e0e0e0;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Helvetica Neue', 'Helvetica', 'Arial', sans-serif;
        font-size: 10px;
        color: var(--dark);
        background: #fff;
        padding: 0 0 100px;
        max-width: 900px;
        margin: 0 auto;
      }

      /* ═══════════════════════════════════════════════
         BANNER HEADER — full width, two-tone
      ═══════════════════════════════════════════════ */
      .banner {
        display: table;
        width: 100%;
        background: var(--dark);
      }
      .banner-logo-cell {
        display: table-cell;
        width: 220px;
        background: var(--accent);
        padding: 22px 24px;
        vertical-align: middle;
      }
      .banner-logo-cell img {
        display: block;
        max-width: 160px;
        max-height: 70px;
      }
      .banner-title-cell {
        display: table-cell;
        vertical-align: middle;
        padding: 22px 28px;
        text-align: right;
      }
      .banner-title {
        font-size: 28px;
        font-weight: 900;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #fff;
        line-height: 1;
      }
      .banner-subtitle {
        font-size: 9px;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--accent);
        margin-top: 5px;
      }

      /* ── SELLER STRIP ─────────────────────────────── */
      .seller-strip {
        display: table;
        width: 100%;
        background: #f7f7f7;
        border-bottom: 1px solid var(--border);
      }
      .seller-strip-left {
        display: table-cell;
        width: 55%;
        padding: 14px 24px;
        vertical-align: middle;
      }
      .seller-strip-right {
        display: table-cell;
        width: 45%;
        padding: 14px 24px;
        vertical-align: middle;
        text-align: right;
        border-left: 1px solid var(--border);
      }
      .seller-name {
        font-size: 11px;
        font-weight: 700;
        color: var(--dark);
        margin-bottom: 3px;
      }
      .seller-detail {
        font-size: 9px;
        color: var(--mid);
        line-height: 1.7;
      }
      .trn-badge {
        display: inline-block;
        background: var(--accent);
        color: var(--dark);
        font-size: 8.5px;
        font-weight: 700;
        letter-spacing: .5px;
        padding: 2px 8px;
        border-radius: 2px;
        margin-top: 5px;
      }

      /* ── INVOICE META TABLE ───────────────────────── */
      .meta-table {
        width: 100%;
        border-collapse: collapse;
      }
      .meta-table td {
        font-size: 9px;
        padding: 2px 0;
        line-height: 1.6;
      }
      .meta-label {
        color: var(--light);
        text-transform: uppercase;
        letter-spacing: .5px;
        font-size: 8px;
        width: 80px;
        text-align: left;
      }
      .meta-value {
        font-weight: 600;
        color: var(--dark);
        text-align: right;
      }
      .meta-value.invoice-num {
        font-size: 13px;
        font-weight: 900;
        color: var(--dark);
      }

      /* ── BODY PADDING ─────────────────────────────── */
      .body-wrap { padding: 24px 44px; }

      /* ── BILL TO ──────────────────────────────────── */
      .bill-row {
        display: table;
        width: 100%;
        margin-bottom: 20px;
      }
      .bill-col {
        display: table-cell;
        width: 50%;
        vertical-align: top;
        padding-right: 24px;
      }
      .bill-col:last-child { padding-right: 0; }
      .section-label {
        font-size: 8px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--light);
        margin-bottom: 8px;
        padding-bottom: 4px;
        border-bottom: 1px solid var(--border);
      }
      .bill-name {
        font-size: 12px;
        font-weight: 700;
        color: var(--dark);
        margin-bottom: 4px;
      }
      .bill-field {
        font-size: 9.5px;
        color: var(--mid);
        line-height: 1.8;
      }
      .bill-trn {
        display: inline-block;
        background: #f0f0f0;
        color: var(--dark);
        font-size: 8.5px;
        font-weight: 700;
        letter-spacing: .5px;
        padding: 2px 8px;
        border-radius: 2px;
        margin-top: 5px;
        border: 1px solid var(--border);
      }

      /* ── ITEMS TABLE ──────────────────────────────── */
      .items-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 24px;
      }
      .items-table thead tr { background: var(--accent); }
      .items-table th {
        padding: 9px 10px;
        font-size: 8.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .8px;
        color: var(--dark);
        text-align: left;
      }
      .items-table th.r { text-align: right; }
      .items-table th.c { text-align: center; }

      .items-table tbody tr { border-bottom: 1px solid var(--border); }
      .items-table tbody tr:last-child { border-bottom: 2px solid var(--dark); }
      .items-table td {
        padding: 9px 10px;
        font-size: 10px;
        vertical-align: middle;
      }
      .item-sub {
        font-size: 8.5px;
        color: var(--light);
        margin-top: 2px;
      }
      .col-item   { width: 42%; }
      .col-qty    { width: 8%;  text-align: center; }
      .col-rate   { width: 20%; text-align: right; }
      .col-amount { width: 20%; text-align: right; font-weight: 600; }
      .col-photo  { width: 10%; text-align: center; }
      .product-thumb {
        width: 38px; height: 38px;
        object-fit: cover;
        border-radius: 3px;
        display: block;
        margin: 0 auto;
      }

      /* ── TOTALS ───────────────────────────────────── */
      .totals-wrap { display: table; width: 100%; }
      .totals-spacer { display: table-cell; width: 55%; }
      .totals-box { display: table-cell; width: 45%; vertical-align: top; }

      .totals-inner {
        border: 1px solid var(--border);
        border-radius: 3px;
        overflow: hidden;
      }
      .t-row {
        display: table;
        width: 100%;
        border-bottom: 1px solid var(--border);
      }
      .t-row:last-child { border-bottom: none; }
      .t-lbl {
        display: table-cell;
        padding: 7px 12px;
        font-size: 9px;
        color: var(--mid);
        width: 55%;
      }
      .t-val {
        display: table-cell;
        padding: 7px 12px;
        font-size: 9px;
        font-weight: 600;
        text-align: right;
        background: #fafafa;
        width: 45%;
      }
      .t-grand { background: var(--dark); }
      .t-grand .t-lbl {
        font-size: 10px;
        font-weight: 700;
        color: #ccc;
      }
      .t-grand .t-val {
        font-size: 13px;
        font-weight: 900;
        color: var(--accent);
        background: var(--dark);
      }

      /* ── WATERMARK ────────────────────────────────── */
      .watermark {
        position: fixed;
        top: 36%;
        left: 0; right: 0;
        text-align: center;
        font-size: 72px;
        font-weight: 900;
        letter-spacing: 6px;
        text-transform: uppercase;
        opacity: 0.05;
        transform: rotate(-28deg);
        z-index: -1;
        color: #000;
      }

      /* ── FOOTER ───────────────────────────────────── */
      .footer {
        position: fixed;
        bottom: 0; left: 0; right: 0;
        background: #fff;
        border-top: 2px solid var(--accent);
        padding: 8px 44px 12px;
        font-size: 8px;
        color: var(--light);
        text-align: center;
        line-height: 1.9;
      }

      @media print {
        body { padding-bottom: 80px; }
        .footer { bottom: 0; }
      }
    </style>
  </head>
  <body>

    <!-- Watermark -->
    <div class="watermark">
      {{#if sale.free}}NOT PAID
      {{else if sale.paidBy}}{{#if (eq sale.paidBy "Credit")}}CREDIT SALE{{else}}PAID{{/if}}
      {{else}}PAID{{/if}}
    </div>

    <!-- ══ BANNER ══ -->
    <div class="banner">
      <div class="banner-logo-cell">
        <img src="{{company.logo}}" alt="{{company.name}}" />
      </div>
      <div class="banner-title-cell">
        <div class="banner-title">Tax Invoice</div>
        <div class="banner-subtitle">Original &nbsp;·&nbsp; VAT Invoice</div>
      </div>
    </div>

    <!-- ══ SELLER STRIP ══ -->
    <div class="seller-strip">
      <div class="seller-strip-left">
        <div class="seller-name">{{company.name}}</div>
        <div class="seller-detail">
          {{company.address}}{{#if company.region}}, {{company.region}}{{/if}}<br/>
          {{#if company.phone}}Tel: {{company.phone}}{{/if}}
          {{#if company.email}}&nbsp;·&nbsp;{{company.email}}{{/if}}
          {{#if company.website}}&nbsp;·&nbsp;{{company.website}}{{/if}}
        </div>
        <span class="trn-badge">TRN: {{company.trn}}</span>
      </div>
      <div class="seller-strip-right">
        <table class="meta-table">
          <tr>
            <td class="meta-label">Invoice #</td>
            <td class="meta-value invoice-num">{{sale.InvoiceCode}}</td>
          </tr>
          <tr>
            <td class="meta-label">Date</td>
            <td class="meta-value">{{formatDate sale.date}}</td>
          </tr>
          <tr>
            <td class="meta-label">Service</td>
            <td class="meta-value">{{sale.service}}</td>
          </tr>
          <tr>
            <td class="meta-label">Prepared By</td>
            <td class="meta-value">{{sale.preparedBy}}</td>
          </tr>
          <tr>
            <td class="meta-label">Payment</td>
            <td class="meta-value">{{#if sale.paidBy}}{{sale.paidBy}}{{else}}—{{/if}}</td>
          </tr>
        </table>
      </div>
    </div>

    <div class="body-wrap">

      <!-- ══ BILL TO ══ -->
<div class="bill-row">
  {{#if billedTo}}
    <div class="bill-col">
      <div class="section-label">Bill To</div>
      <div class="bill-name">{{billedTo.name}}</div>
      {{#if billedTo.address}}<div class="bill-field">{{billedTo.address}}</div>{{/if}}
      {{#if billedTo.poBox}}<div class="bill-field">PO Box: {{billedTo.poBox}}</div>{{/if}}
      {{#if billedTo.phone}}<div class="bill-field">{{billedTo.phone}}</div>{{/if}}
      {{#if billedTo.taxRegNumber}}<span class="bill-trn">TRN: {{billedTo.taxRegNumber}}</span>{{/if}}
    </div>
  {{else}}
    <div class="bill-col">
      <div class="section-label">Bill To</div>
      <div class="bill-name">{{#if sale.name}}{{sale.name}}{{else}}Walk-in Customer{{/if}}</div>
      {{#if sale.phone}}<div class="bill-field">{{sale.phone}}</div>{{/if}}
    </div>
  {{/if}}
</div>

      <!-- ══ ITEMS TABLE ══ -->
      <table class="items-table">
        <thead>
          <tr>
            <th class="col-item">Item / Description</th>
            <th class="col-qty c">Qty</th>
            <th class="col-rate r">Unit Price</th>
            <th class="col-amount r">Amount</th>
          </tr>
        </thead>
        <tbody>
          {{#each sale.saleItems}}
          <tr>
            <td class="col-item">
              {{productName}}
              {{#if arrangement}}<div class="item-sub">{{arrangement}}</div>{{/if}}
            </td>
            <td class="col-qty">{{quantity}}</td>
            <td class="col-rate">AED {{formatCurrency price}}</td>
            <td class="col-amount">AED {{formatCurrency total}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <!-- ══ TOTALS ══ -->
      <div class="totals-wrap">
        <div class="totals-spacer"></div>
        <div class="totals-box">
          <div class="totals-inner">
            <div class="t-row">
              <div class="t-lbl">Net Amount (excl. VAT)</div>
              <div class="t-val">AED {{formatCurrency sale.subTotal}}</div>
            </div>
            {{#if sale.discount}}
            <div class="t-row">
              <div class="t-lbl">Discount</div>
              <div class="t-val">− AED {{formatCurrency sale.discount}}</div>
            </div>
            {{/if}}
            <div class="t-row">
              <div class="t-lbl">VAT (5%)</div>
              <div class="t-val">AED {{formatCurrency sale.vat}}</div>
            </div>
            <div class="t-row t-grand">
              <div class="t-lbl">Total Due</div>
              <div class="t-val">AED {{formatCurrency sale.total}}</div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /body-wrap -->

    <!-- ══ FOOTER ══ -->
    <div class="footer">
      <p>{{company.name}} &nbsp;|&nbsp; {{company.address}}{{#if company.region}}, {{company.region}}{{/if}} &nbsp;|&nbsp; TRN: {{company.trn}}</p>
      <p>
        {{#if company.website}}{{company.website}}{{/if}}
        {{#if company.phone}}&nbsp;·&nbsp;Tel: {{company.phone}}{{/if}}
        {{#if company.email}}&nbsp;·&nbsp;{{company.email}}{{/if}}
      </p>
      <p style="margin-top:3px; font-style:italic;">This is a computer-generated invoice and does not require a signature.</p>
    </div>

  </body>
</html>